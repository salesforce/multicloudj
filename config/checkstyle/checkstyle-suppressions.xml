<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Allow single-character member names in test helper classes -->
    <suppress checks="MemberName"
              files=".*[\\/]src[\\/]test[\\/].*"/>

    <!-- Allow flexible method naming in test classes (underscores for readability) -->
    <suppress checks="MethodName"
              files=".*[\\/]src[\\/]test[\\/].*"/>

    <!-- Suppress checkstyle for JMH benchmark test files and ad-hoc test utilities (pre-date checkstyle enforcement) -->
    <suppress checks=".*" files=".*BenchmarkTest\.java"/>
    <suppress checks=".*" files="QuickConnectionTest\.java"/>
</suppressions>
